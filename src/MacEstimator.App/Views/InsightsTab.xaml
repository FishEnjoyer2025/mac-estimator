<UserControl x:Class="MacEstimator.App.Views.InsightsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MacEstimator.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:InsightsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundDark}"
             Loaded="OnLoaded">

    <ScrollViewer x:Name="OuterScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  Padding="16">
        <StackPanel Margin="16">
            <!-- Header -->
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right"
                        Content="{Binding RefreshButtonText}"
                        Style="{StaticResource GhostButtonStyle}"
                        Padding="12,4"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding IsNotRefreshing}"
                        Command="{Binding RefreshDataCommand}"/>
                <TextBlock Text="BUSINESS INSIGHTS"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource ForegroundSecondary}"
                       FontSize="{StaticResource FontSizeSmall}"
                       Margin="0,0,0,16"/>

            <!-- Summary Cards Row -->
            <UniformGrid Rows="1" Margin="0,0,0,20">
                <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="0" Margin="0,0,8,0" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="4" Background="{StaticResource AccentBrush}" CornerRadius="6,0,0,6"/>
                        <StackPanel Margin="14,14,16,14">
                            <TextBlock Text="Total Bids" Foreground="{StaticResource ForegroundSecondary}" FontSize="{StaticResource FontSizeSmall}"/>
                            <TextBlock Text="{Binding TotalBids}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentLightBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="0" Margin="4,0" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="4" Background="{StaticResource AccentBrush}" CornerRadius="6,0,0,6"/>
                        <StackPanel Margin="14,14,16,14">
                            <TextBlock Text="Jobs Costed" Foreground="{StaticResource ForegroundSecondary}" FontSize="{StaticResource FontSizeSmall}"/>
                            <TextBlock Text="{Binding TotalJobsCosted}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentLightBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="0" Margin="4,0" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="4" Background="{StaticResource SuccessBrush}" CornerRadius="6,0,0,6"/>
                        <StackPanel Margin="14,14,16,14">
                            <TextBlock Text="Win Rate" Foreground="{StaticResource ForegroundSecondary}" FontSize="{StaticResource FontSizeSmall}"/>
                            <TextBlock Text="{Binding OverallWinRate}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="0" Margin="8,0,0,0" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="4" Background="{StaticResource SuccessBrush}" CornerRadius="6,0,0,6"/>
                        <StackPanel Margin="14,14,16,14">
                            <TextBlock Text="Avg Profit Margin" Foreground="{StaticResource ForegroundSecondary}" FontSize="{StaticResource FontSizeSmall}"/>
                            <TextBlock Text="{Binding AvgProfitMargin}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <!-- Two columns -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">

                    <!-- Win Rates by Year -->
                    <Border Background="{StaticResource BackgroundDarkest}" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="WIN RATES BY YEAR" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding YearRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="{StaticResource BackgroundMedium}"
                                      AlternatingRowBackground="{StaticResource BackgroundDarkest}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="60"/>
                                    <DataGridTextColumn Header="Won" Binding="{Binding Won}" Width="50"/>
                                    <DataGridTextColumn Header="Lost" Binding="{Binding Lost}" Width="50"/>
                                    <DataGridTextColumn Header="Rate" Binding="{Binding WinRate}" Width="60"/>
                                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Estimator Performance -->
                    <Border Background="{StaticResource BackgroundDarkest}" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="TEAM STATS" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding EstimatorRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="{StaticResource BackgroundMedium}"
                                      AlternatingRowBackground="{StaticResource BackgroundDarkest}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Estimator" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Bids" Binding="{Binding Bids}" Width="50"/>
                                    <DataGridTextColumn Header="Won" Binding="{Binding Won}" Width="45"/>
                                    <DataGridTextColumn Header="Win%" Binding="{Binding WinRate}" Width="50"/>
                                    <DataGridTextColumn Header="Rev Won" Binding="{Binding RevenueWon}" Width="90"/>
                                    <DataGridTextColumn Header="Margin" Binding="{Binding AvgMargin}" Width="55"/>
                                    <DataGridTextColumn Header="Costed" Binding="{Binding JobCount}" Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Seasonal -->
                    <Border Background="{StaticResource BackgroundDarkest}" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SEASONAL PATTERNS" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding SeasonalRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="{StaticResource BackgroundMedium}"
                                      AlternatingRowBackground="{StaticResource BackgroundDarkest}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="60"/>
                                    <DataGridTextColumn Header="Bids" Binding="{Binding BidCount}" Width="60"/>
                                    <DataGridTextColumn Header="Total Value" Binding="{Binding TotalValue}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">

                    <!-- Top Contractors -->
                    <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="TOP CONTRACTORS" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding ContractorRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="{StaticResource BackgroundMedium}"
                                      AlternatingRowBackground="{StaticResource BackgroundDarkest}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Contractor" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Jobs" Binding="{Binding Jobs}" Width="50"/>
                                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Most Profitable Jobs -->
                    <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MOST PROFITABLE (by $ earned)" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding TopJobs}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="{StaticResource BackgroundMedium}"
                                      AlternatingRowBackground="{StaticResource BackgroundDarkest}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Job" Binding="{Binding Job}" Width="70"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Margin" Binding="{Binding Margin}" Width="60"/>
                                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue}" Width="90"/>
                                    <DataGridTextColumn Header="Profit" Binding="{Binding Profit}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Least Profitable Jobs -->
                    <Border Background="{StaticResource BackgroundMedium}" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="LEAST PROFITABLE (by $ earned)" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding WorstJobs}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="{StaticResource BackgroundMedium}"
                                      AlternatingRowBackground="{StaticResource BackgroundDarkest}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Job" Binding="{Binding Job}" Width="70"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Margin" Binding="{Binding Margin}" Width="60"/>
                                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue}" Width="90"/>
                                    <DataGridTextColumn Header="Profit" Binding="{Binding Profit}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
