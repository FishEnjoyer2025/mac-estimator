<Window x:Class="MacEstimator.App.JobHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job History"
        Width="900" Height="500"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Assets/app.ico">

    <DockPanel Margin="16">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="SHARED JOB HISTORY"
                   FontWeight="Bold"
                   FontSize="16"
                   Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,12"/>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Open Selected"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="16,8"
                    Click="OnOpenClick"
                    Margin="0,0,8,0"/>
            <Button Content="Close"
                    Style="{StaticResource GhostButtonStyle}"
                    Padding="16,8"
                    Click="OnCloseClick"/>
        </StackPanel>

        <!-- Job list -->
        <ListView x:Name="JobList"
                  Background="{StaticResource BackgroundMedium}"
                  Foreground="{StaticResource ForegroundPrimary}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  MouseDoubleClick="OnJobDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Job Name" Width="180"
                                    DisplayMemberBinding="{Binding JobName}"/>
                    <GridViewColumn Header="Job #" Width="70"
                                    DisplayMemberBinding="{Binding JobNumber}"/>
                    <GridViewColumn Header="Client" Width="160"
                                    DisplayMemberBinding="{Binding ClientCompany}"/>
                    <GridViewColumn Header="Total" Width="100"
                                    DisplayMemberBinding="{Binding Total, StringFormat=C2}"/>
                    <GridViewColumn Header="Submitted By" Width="120"
                                    DisplayMemberBinding="{Binding SubmittedBy}"/>
                    <GridViewColumn Header="Last Modified" Width="100"
                                    DisplayMemberBinding="{Binding ModifiedAt, StringFormat=M/d/yyyy}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
